{
  "name": "typewriting",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron electron.cjs\"",
    "electron:build": "npm run build && electron-builder && node scripts/copy-build.cjs"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "firebase": "^12.15.0",
    "lucide-react": "^1.18.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.2",
    "electron": "^34.0.2",
    "electron-builder": "^25.1.8",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "wait-on": "^8.0.2"
  },
  "build": {
    "appId": "com.farmaal.typewriting",
    "productName": "Farmaal",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "!dist/downloads/**/*",
      "electron.cjs",
      "package.json"
    ],
    "win": {
      "icon": "public/logo.png",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Farmaal",
      "artifactName": "Farmaal_Setup.exe",
      "include": "build/installer.nsh"
    }
  }
}
